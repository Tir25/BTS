{
  "name": "bus-tracking-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:restart": "node scripts/restart-dev-server.js",
    "dev:local": "vite --mode development",
    "build": "node scripts/unified-build.js --profile=production",
    "build:dev": "node scripts/unified-build.js --profile=development",
    "build:staging": "node scripts/unified-build.js --profile=staging",
    "build:production": "node scripts/unified-build.js --profile=production",
    "build:docker": "node scripts/unified-build.js --profile=production --platform=docker",
    "build:vercel": "node scripts/unified-build.js --profile=production --platform=vercel",
    "build:render": "node scripts/unified-build.js --profile=production --platform=render",
    "preview": "npx vite preview",
    "lint": "eslint src/**/*.{ts,tsx} --ext ts,tsx --max-warnings 20",
    "lint:fix": "eslint src/**/*.{ts,tsx} --ext ts,tsx --fix",
    "format": "prettier --write src/**/*.{ts,tsx,js,jsx}",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "analyze": "npm run build && npx vite-bundle-analyzer dist",
    "vercel-build": "node scripts/unified-build.js --profile=production --platform=vercel",
    "validate-structure": "node scripts/validate-structure.js",
    "validate-deployment": "node scripts/validate-deployment-config.js",
    "cleanup": "node scripts/cleanup-and-verify.js",
    "env:validate": "node scripts/validate-env.js",
    "env:setup": "node scripts/setup-env.js",
    "config:validate": "node scripts/validate-config.js",
    "deps:check": "node scripts/dependency-manager.cjs check",
    "deps:update": "node scripts/dependency-manager.cjs update",
    "deps:clean": "node scripts/dependency-manager.cjs clean",
    "deps:report": "node scripts/dependency-manager.cjs report",
    "deps:audit": "npm audit --audit-level=moderate",
    "deps:outdated": "npm outdated",
    "deps:security": "npm audit --audit-level=high",
    "deps:fix": "npm audit fix --audit-level=moderate",
    "deps:optimize": "npm run deps:check && npm run deps:fix && npm run deps:update",
    "pre-commit": "node scripts/pre-commit-deps.cjs && npm run validate-structure && npm run config:validate && npm run lint && npm run type-check"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.56.0",
    "@tanstack/react-query": "^5.85.5",
    "@tanstack/react-query-devtools": "^5.90.2",
    "framer-motion": "^10.16.16",
    "glob": "^10.4.5",
    "leaflet": "^1.9.4",
    "maplibre-gl": "^3.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.20.1",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^3.4.18",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^24.9.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.0.3",
    "@vitest/ui": "^4.0.3",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jest": "^30.2.0",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "puppeteer": "^24.26.1",
    "typescript": "^5.2.2",
    "vite": "^5.4.21",
    "vite-bundle-analyzer": "^1.2.3",
    "vite-plugin-compression2": "^2.2.0",
    "vitest": "^4.0.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
