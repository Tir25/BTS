# =============================================================================
# 🚀 PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# University Bus Tracking System - Frontend
# =============================================================================

# =============================================================================
# 🔐 CRITICAL SECURITY VARIABLES - REGENERATE THESE BEFORE PRODUCTION
# =============================================================================

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# =============================================================================
# 🌐 API CONFIGURATION
# =============================================================================

# Backend API URL (optional - will auto-detect in most cases)
# VITE_API_URL=https://your-backend-domain.com

# WebSocket URL (optional - will auto-detect in most cases)
# VITE_WEBSOCKET_URL=wss://your-backend-domain.com

# =============================================================================
# 🏗️ BUILD CONFIGURATION
# =============================================================================

# Build mode
VITE_BUILD_MODE=production

# =============================================================================
# 🗺️ MAP CONFIGURATION
# =============================================================================

# MapLibre Token (Optional - for enhanced map features)
# VITE_MAPLIBRE_TOKEN=your_maplibre_token_here

# =============================================================================
# 👥 ADMIN CONFIGURATION
# =============================================================================

# Admin emails (comma-separated)
VITE_ADMIN_EMAILS=admin1@example.com,admin2@example.com

# =============================================================================
# 🔧 PRODUCTION CONFIGURATION
# =============================================================================

# Development mode flag (should be false in production)
VITE_DEV_MODE=false

# Debug logging (should be false in production)
VITE_DEBUG_LOGS=false

# =============================================================================
# 📊 PERFORMANCE CONFIGURATION
# =============================================================================

# API timeout (milliseconds)
VITE_API_TIMEOUT=15000

# API retry attempts
VITE_API_RETRY_ATTEMPTS=5

# Map configuration
VITE_MAP_DEFAULT_ZOOM=12
VITE_MAP_MAX_ZOOM=18
VITE_MAP_MIN_ZOOM=8

# Feature flags
VITE_ENABLE_CLUSTERING=true
VITE_ENABLE_HEATMAP=true
VITE_ENABLE_OFFLINE_MODE=false
VITE_ENABLE_PUSH_NOTIFICATIONS=true
VITE_ENABLE_PERFORMANCE_MONITORING=true

# Performance thresholds
VITE_SLOW_RENDER_THRESHOLD=16
VITE_MAX_RENDER_COUNT=100
VITE_LOCATION_UPDATE_INTERVAL=3000
VITE_MAP_UPDATE_THROTTLE=500
VITE_MAX_CONCURRENT_REQUESTS=10
VITE_REQUEST_TIMEOUT=15000

# WebSocket configuration
VITE_WS_CONNECTION_TIMEOUT=30000
VITE_WS_HEARTBEAT_INTERVAL=30000
VITE_WS_MAX_RECONNECT_ATTEMPTS=10
VITE_WS_RECONNECT_DELAY=1000
VITE_WS_MAX_RECONNECT_DELAY=30000

# Authentication configuration
VITE_SESSION_TIMEOUT=86400000
VITE_TOKEN_REFRESH_THRESHOLD=300000
VITE_MAX_TOKEN_REFRESH_ATTEMPTS=3

# Error handling configuration
VITE_MAX_RETRY_ATTEMPTS=5
VITE_RETRY_DELAY=1000
VITE_EXPONENTIAL_BACKOFF=true

# =============================================================================
# 🛡️ SECURITY CONFIGURATION
# =============================================================================

# Content Security Policy (optional)
# VITE_CSP_NONCE=your_csp_nonce_here

# =============================================================================
# 📊 ANALYTICS & MONITORING (optional)
# =============================================================================

# Google Analytics (optional)
# VITE_GA_TRACKING_ID=your_ga_tracking_id

# Error tracking (optional)
# VITE_SENTRY_DSN=your_sentry_dsn

# =============================================================================
# 🚨 PRODUCTION SECURITY CHECKLIST
# =============================================================================
# ✅ Supabase keys regenerated
# ✅ HTTPS configured
# ✅ CSP headers enabled
# ✅ Environment variables secured
# ✅ Build optimized
# ✅ Error tracking configured
# ✅ Analytics configured (if needed)
# ✅ Performance settings optimized for production
# =============================================================================
