{
  "name": "university-bus-tracking-system",
  "version": "1.0.0",
  "description": "Real-time bus tracking system for university students and faculty",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build": "npm run build --workspaces",
    "build:backend": "npm run build --workspace=backend",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:fix": "npm run lint:fix:backend && npm run lint:fix:frontend",
    "lint:fix:backend": "cd backend && npm run lint:fix",
    "lint:fix:frontend": "cd frontend && npm run lint:fix",
    "format": "npm run format:backend && npm run format:frontend",
    "format:backend": "cd backend && npm run format",
    "format:frontend": "cd frontend && npm run format",
    "start": "npm run start:backend",
    "start:backend": "npm run start --workspace=backend",
    "start:frontend": "npm run start --workspace=frontend",
    "test:backend": "cd backend && node test-server.js",
    "test:minimal": "cd backend && node minimal-test.js",
    "health": "node health-check.js",
    "health:backend": "curl http://localhost:3000/health",
    "health:frontend": "curl http://localhost:5173",
    "monitor": "node server-monitor.js",
    "monitor:dashboard": "node server-monitor.js dashboard",
    "monitor:continuous": "node server-monitor.js monitor",
    "monitor:check": "node server-monitor.js check",
    "monitor:performance": "node server-monitor.js performance",
    "migrate": "cd backend && node -e \"require('./src/utils/migrationRunner').default.getInstance().runMigrations()\"",
    "migrate:status": "cd backend && node -e \"require('./src/utils/migrationRunner').default.getInstance().checkMigrationStatus().then(console.log)\"",
    "test:websocket-auth": "node scripts/test-websocket-auth.js",
    "test:driver-dashboard": "node scripts/verify-driver-dashboard.js",
    "test:admin-driver-sync": "node scripts/test-admin-driver-sync.js",
    "verify:driver": "npm run test:driver-dashboard",
    "verify:admin-sync": "npm run test:admin-driver-sync"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "puppeteer": "^24.26.1",
    "vite": "^5.4.21"
  },
  "keywords": [
    "bus-tracking",
    "university",
    "react",
    "nodejs",
    "postgresql",
    "postgis",
    "supabase",
    "realtime"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.76.1",
    "axios": "^1.12.2"
  }
}
