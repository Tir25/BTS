# 🚌 University Bus Tracking System - Environment Configuration Example
# Copy this file to .env.local for development or .env.production for production

# =============================================================================
# 🛡️ Core Application Settings
# =============================================================================
NODE_ENV=development # Options: development, production
PORT=3000            # Port for the Express server

# =============================================================================
# 🔑 Supabase Configuration (Required)
# =============================================================================
# Project URL from Supabase dashboard
SUPABASE_URL=https://your-project-ref.supabase.co

# API Keys from Supabase dashboard -> Project Settings -> API
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# =============================================================================
# 🗄️ Database Configuration (Required)
# =============================================================================
# Connection string from Supabase dashboard -> Project Settings -> Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/bus_tracking

# Connection Pool Settings (Optional - defaults shown)
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=10000
DB_RETRY_DELAY=5000
DB_MAX_RETRIES=5

# =============================================================================
# 🌐 CORS & Security Configuration
# =============================================================================
# Comma-separated list of allowed origins (Optional)
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# CORS settings (Optional - defaults shown)
CORS_CREDENTIALS=true
ENABLE_HELMET=true
ENABLE_CORS=true

# Rate Limiting (Optional - defaults shown)
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_REQUESTS=5
ENABLE_RATE_LIMIT=true

# =============================================================================
# 📊 Logging Configuration
# =============================================================================
# Log Levels: error, warn, info, debug (Optional - defaults to 'debug' in development)
LOG_LEVEL=debug
ENABLE_DEBUG_LOGS=true        # Set to false in production

# =============================================================================
# 🧪 Development & Testing Credentials
# =============================================================================
# Default credentials for development
DRIVER_TEST_EMAIL=driver@example.com
DRIVER_TEST_PASSWORD=driver_test_password

ADMIN_TEST_EMAIL=admin@example.com
ADMIN_TEST_PASSWORD=admin_test_password

# =============================================================================
# ⚠️ Security Notice ⚠️
# =============================================================================
# NEVER commit this file with real credentials to version control
# For production, use environment variables set directly on the server
# or through a secure secrets management system
